generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTHENTIFICATION (better-auth)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("agent")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ============================================================
// CODE MINIER
// Structure: Titre → Chapitre → Section → Article → Paragraphe
// ============================================================

model CodeMinierTitre {
  id        String   @id @default(cuid())
  numero    String
  titre     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapitres CodeMinierChapitre[]

  @@map("code_minier_titres")
}

model CodeMinierChapitre {
  id        String   @id @default(cuid())
  numero    String
  titre     String
  titreId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titre_rel CodeMinierTitre?    @relation(fields: [titreId], references: [id], onDelete: SetNull)
  sections  CodeMinierSection[]
  articles  CodeMinierArticle[]

  @@map("code_minier_chapitres")
}

model CodeMinierSection {
  id         String   @id @default(cuid())
  numero     String
  titre      String
  chapitreId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  chapitre CodeMinierChapitre  @relation(fields: [chapitreId], references: [id], onDelete: Cascade)
  articles CodeMinierArticle[]

  @@map("code_minier_sections")
}

model CodeMinierArticle {
  id           String   @id @default(cuid())
  numero       String
  titre        String
  chapitreId   String
  sectionId    String?
  modification String?
  introduction String?
  contenu      String?
  keywords     String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  chapitre    CodeMinierChapitre   @relation(fields: [chapitreId], references: [id], onDelete: Cascade)
  section     CodeMinierSection?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  paragraphes CodeMinierParagraphe[]

  @@map("code_minier_articles")
}

model CodeMinierParagraphe {
  id        String   @id @default(cuid())
  numero    String
  contenu   String
  note      String?
  articleId String
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article CodeMinierArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("code_minier_paragraphes")
}

// ============================================================
// RÈGLEMENT MINIER
// Structure: Titre → Chapitre → Article → Paragraphe
// ============================================================

model ReglementTitre {
  id        String   @id @default(cuid())
  numero    String
  titre     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapitres ReglementChapitre[]
  articles  ReglementArticle[]

  @@map("reglement_titres")
}

model ReglementChapitre {
  id        String   @id @default(cuid())
  numero    String
  titre     String
  titreId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titre_rel ReglementTitre     @relation(fields: [titreId], references: [id], onDelete: Cascade)
  articles  ReglementArticle[]

  @@map("reglement_chapitres")
}

model ReglementArticle {
  id         String   @id @default(cuid())
  numero     String
  titre      String
  chapitreId String
  titreId    String
  keywords   String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  chapitre    ReglementChapitre     @relation(fields: [chapitreId], references: [id], onDelete: Cascade)
  titre_rel   ReglementTitre        @relation(fields: [titreId], references: [id], onDelete: Cascade)
  paragraphes ReglementParagraphe[]

  @@map("reglement_articles")
}

model ReglementParagraphe {
  id        String   @id @default(cuid())
  numero    String
  contenu   String
  note      String?
  articleId String
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article ReglementArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("reglement_paragraphes")
}

// ============================================================
// CONFLITS MINIERS
// ============================================================

enum ConflitStatut {
  en_cours
  resolu
  appel
}

model Conflit {
  id            String        @id @default(cuid())
  reference     String        @unique
  type          String
  parties       String
  zone          String
  dateOuverture DateTime
  statut        ConflitStatut @default(en_cours)
  decision      String?
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("conflits")
}

// ============================================================
// JURISPRUDENCE
// ============================================================

enum JurisprudenceImportance {
  haute
  moyenne
  normale
}

model Jurisprudence {
  id          String                  @id @default(cuid())
  reference   String                  @unique
  titre       String
  juridiction String
  date        DateTime
  resume      String
  importance  JurisprudenceImportance @default(normale)
  texteComplet String?
  matieres    String[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@map("jurisprudences")
}

// ============================================================
// JOURNAL OFFICIEL
// ============================================================

model JournalOfficiel {
  id        String   @id @default(cuid())
  numero    String   @unique
  date      DateTime
  titre     String
  categorie String
  resume    String
  pageDebut Int
  pageFin   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("journal_officiel")
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id           String   @id @default(cuid())
  nom          String
  categorie    String
  dateEcheance DateTime
  contenu      Bytes
  taille       Int
  mimeType     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("documents")
}
